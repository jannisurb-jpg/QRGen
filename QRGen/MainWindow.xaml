<Window x:Class="QRGen.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QRGen"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundColor}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="25"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Grid Background="{StaticResource TitleBarColor}"
            Grid.ColumnSpan="2"
              MouseDown="Grid_MouseDown">

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Image Source="pack://application:,,,/Images/logo.png"
                   VerticalAlignment="Center"
                   Margin="3"/>

            <TextBlock Text="QRGen"
                       Foreground="{StaticResource PrimaryText}"
                       Grid.Column="1"
                       VerticalAlignment="Center"
                       FontWeight="Medium">
                
            </TextBlock>
            
            <TextBlock Text="QR Code"
                       Foreground="{StaticResource SecondaryText}"
                       Grid.Column="2"
                       VerticalAlignment="Center">

            </TextBlock>

            <TextBlock Text="Bar Code"
                       Foreground="{StaticResource SecondaryText}"
                       Grid.Column="3"
                       VerticalAlignment="Center">

            </TextBlock>

            <Button Content="X"
                    Grid.Column="13"
                    Background="Transparent"
                    Foreground="White"
                    Click="Close_window"/>

            <Button Content="-"
                    Grid.Column="12"
                    Background="Transparent"
                    Foreground="White"
                    Click="Minimize_window"/>

        </Grid>

        <Grid Grid.Row="1">
            <StackPanel Orientation="Vertical"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <Image x:Name="QRImage"
               Width="200"
               Height="200"
               Margin="0,0,0,20"/>

                <TextBox x:Name="InputBox"
                 Width="400"
                 TextAlignment="Center"
                 Margin="0,0,0,10"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">
                    <Button Content="QR Code" 
                            Margin="10"
                            Click="CreateQR"/>
                    <Button Content="Bar Code" Margin="10"/>
                </StackPanel>
            </StackPanel>
        </Grid>
        
        </Grid>
</Window>
