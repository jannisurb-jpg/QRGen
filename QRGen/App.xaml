<Application x:Class="QRGen.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:QRGen"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="BackgroundColor" Color="#181735"/>
           <SolidColorBrush x:Key="TitleBarColor" Color="#0F0F2D"/>
           <SolidColorBrush x:Key="PrimaryText" Color="White"/>
            <SolidColorBrush x:Key="SecondaryText" Color="LightGray"/>
            <SolidColorBrush x:Key="AccentColor" Color="#0078D7"/>
        </Application.Resources>
</Application>
